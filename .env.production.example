# Production Environment Configuration
# Copy this to .env.production and fill in your values

# Database
DATABASE_URL=postgresql://user:password@host:5432/vibekit_prod
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=7d
BCRYPT_ROUNDS=12

# API Configuration
API_BASE_URL=https://your-domain.com
API_TIMEOUT=30000
MAX_RETRIES=3
RETRY_DELAY=1000

# Frontend
VITE_API_BASE=https://your-domain.com/.netlify/functions
VITE_APP_NAME=VibeKit Studio
VITE_APP_URL=https://your-domain.com

# Netlify
NETLIFY_SITE_ID=your-site-id
NETLIFY_AUTH_TOKEN=your-auth-token

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn
ENABLE_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Storage (for future image uploads)
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
AWS_BUCKET=vibekit-studio-prod

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CUSTOM_DOMAINS=false
ENABLE_TEMPLATES=false
ENABLE_COLLABORATION=false